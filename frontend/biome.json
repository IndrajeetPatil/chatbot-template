{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git"
  },
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/.fallow",
      "!**/.lighthouseci",
      "!**/coverage",
      "!**/dist",
      "!**/playwright-report",
      "!**/test-results",
      "!**/tsconfig.tsbuildinfo",
      "!node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto",
    "bracketSpacing": true,
    "includes": [
      "**",
      "!**/.next/**",
      "!**/.fallow/**",
      "!**/.lighthouseci/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/playwright-report/**",
      "!**/test-results/**",
      "!**/tsconfig.tsbuildinfo",
      "!node_modules/**"
    ]
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 5
          }
        }
      },
      "style": {
        "noNamespace": "error",
        "useAsConstAssertion": "error"
      }
    },
    "includes": [
      "**",
      "!**/.next/**",
      "!**/.fallow/**",
      "!**/.lighthouseci/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/playwright-report/**",
      "!**/test-results/**",
      "!**/tsconfig.tsbuildinfo",
      "!node_modules/**"
    ]
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "quoteStyle": "double",
      "attributePosition": "multiline",
      "bracketSpacing": true
    },
    "globals": []
  },
  "css": {
    "linter": {
      "enabled": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredVariables": "off",
            "useImportExtensions": "off"
          },
          "suspicious": {
            "noReactSpecificProps": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
