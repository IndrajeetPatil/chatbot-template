{
  "name": "chatbot-template-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "rm -rf dist && vite build",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "check-types": "tsc --noemit",
    "lint": "biome check --write --unsafe app client components e2e-tests src index.html *.json *.ts",
    "test": "vitest run --coverage",
    "test:update": "vitest run --update",
    "test:e2e": "npx playwright test",
    "fallow": "fallow --fail-on-issues --quiet",
    "css-quality": "node scripts/css-quality.mjs",
    "contrast-audit": "node scripts/contrast-audit.mjs",
    "lint:security": "eslint app client components src",
    "type-coverage": "type-coverage --strict --at-least 100"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.15",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/utils": "^9.2.0",
    "ai": "^7.0.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@projectwallace/css-code-quality": "^3.1.3",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-dom": "^5.10.3",
    "fallow": "^2.104.0",
    "globals": "^17.7.0",
    "http-status-codes": "^2.3.0",
    "jsdom": "^29.1.1",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
